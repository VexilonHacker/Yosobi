[0.002, "o", "       █████ █████                           █████      ███ \r\n      ░░███ ░░███                           ░░███      ░░░  \r\n       ░░███ ███    ██████   █████   ██████  ░███████  ████ \r\n        ░░█████    ███░░███ ███░░   ███░░███ ░███░░███░░███ \r\n         ░░███    ░███ ░███░░█████ ░███ ░███ ░███ ░███ ░███ \r\n          ░███    ░███ ░███ ░░░░███░███ ░███ ░███ ░███ ░███ \r\n          █████   ░░██████  ██████ ░░██████  ████████  █████\r\n         ░░░░░     ░░░░░░  ░░░░░░   ░░░░░░  ░░░░░░░░  ░░░░░ \r\n                                                            \r\n"]
[0.000, "o", "\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;33mOptions:\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;32m-u, --url\u001b[0m               YouTube URL (video or playlist)\r\n"]
[0.000, "o", "  \u001b[1;32m-f, --format\u001b[0m            Preselected format code (e.g. 247, 251)\r\n  \u001b[1;32m-d, --dir\u001b[0m               Override base output directory (Videos/Music)\r\n"]
[0.000, "o", "  \u001b[1;32m-o, --output\u001b[0m            Custom output file name (no extension)\r\n  \u001b[1;32m-oo, --output-path\u001b[0m      Exact output file path (e.g. /path/to/file.mp3)\r\n"]
[0.000, "o", "  \u001b[1;32m-s, --subs\u001b[0m              Download subtitles\r\n  \u001b[1;32m-sf, --sub-format\u001b[0m       Subtitle format: lrc, vtt, srt, txt (default: lrc audio, vtt video)\r\n"]
[0.000, "o", "  \u001b[1;32m-so, --subs-only\u001b[0m        Download ONLY subtitles (no media)\r\n"]
[0.000, "o", "  \u001b[1;32m-m, --max-retries\u001b[0m       Set max retries (default: 3)\r\n"]
[0.000, "o", "  \u001b[1;32m-c, --concurrent\u001b[0m        Concurrent fragments for download (default: 5)\r\n"]
[0.000, "o", "  \u001b[1;32m-hs, --history\u001b[0m          Show download history\r\n"]
[0.000, "o", "  \u001b[1;32m-ch, --clear-history\u001b[0m    Delete all download history\r\n"]
[0.000, "o", "  \u001b[1;32m-h, --help\u001b[0m              Show this help menu\r\n"]
[0.000, "o", "  \u001b[1;32m-ex, --examples\u001b[0m         Show advanced usage examples\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1;33mCommands:\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;32mdownload\u001b[0m (default)       Download video/audio with yt-dlp\r\n"]
[0.000, "o", "  \u001b[1;32mplay\u001b[0m                     Stream audio (or video) with mpv\r\n"]
[0.000, "o", "  \u001b[1;32msleep\u001b[0m                    Stream audio and then suspend the system\r\n"]
[0.000, "o", "  \u001b[1;32minfo\u001b[0m                      Fetch video/audio metadata as JSON\r\n"]
[0.000, "o", "  \u001b[1;32mmpc\u001b[0m                      Update MPD playlist (adds all music)\r\n\r\n"]
[0.001, "o", "\u001b[1;33mMPC usage:\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;32m/usr/local/bin/yosobi mpc [--newest]\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[1;33mPlay/Sleep usage:\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;32m/usr/local/bin/yosobi play [--video] <url> [mpv options ...]\u001b[0m\r\n  \u001b[1;32m/usr/local/bin/yosobi sleep [--video] <url> [mpv options ...]\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[1;33mExamples:\u001b[0m\r\n  \u001b[1;36m/usr/local/bin/yosobi -u 'URL'\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi -u 'URL' -s -sf lrc\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi -oo '/home/user/Music/song.mp3' -f 251\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi play 'URL' --volume=80\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi play --video 'URL' --start=60\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi sleep 'URL'\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi info 'URL'\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi mpc --newest\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi --history\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi --clear-history\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;36m/usr/local/bin/yosobi --examples\u001b[0m  (show advanced examples)\r\n\r\n"]
