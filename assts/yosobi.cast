[0.233, "o", "\u001b[1C\u001b[39m \u001b[33m'\u001b[33mh\u001b[33mt\u001b[33mt\u001b[33mp\u001b[33ms\u001b[33m:\u001b[33m/\u001b[33m/\u001b[2C\u001b[33mw\u001b[33m.\u001b[33my\u001b[33mo\u001b[33mu\u001b[33mt\u001b[33mu\u001b[33mb\u001b[33me\u001b[33m.\u001b[33mc\u001b[33mo\u001b[33mm\u001b[33m/\u001b[33mw\u001b[33ma\u001b[33mt\u001b[33mc\u001b[33mh\u001b[33m?\u001b[33mv\u001b[33m=\u001b[33md\u001b[33mQ\u001b[33mw\u001b[33m4\u001b[33mw\u001b[33m9\u001b[33mW\u001b[33mg\u001b[33mX\u001b[33mc\u001b[33mQ\u001b[33m'\u001b[39m \u001b[47D"]
[0.376, "o", "\u001b[32m-\u001b[39m\u001b[39m \u001b[33m'\u001b[33mh\u001b[33mt\u001b[33mt\u001b[33mp\u001b[33ms\u001b[33m:\u001b[33m/\u001b[33m/\u001b[2C\u001b[33mw\u001b[33m.\u001b[33my\u001b[33mo\u001b[33mu\u001b[33mt\u001b[33mu\u001b[33mb\u001b[33me\u001b[33m.\u001b[33mc\u001b[33mo\u001b[33mm\u001b[33m/\u001b[33mw\u001b[33ma\u001b[33mt\u001b[33mc\u001b[33mh\u001b[33m?\u001b[33mv\u001b[33m=\u001b[33md\u001b[33mQ\u001b[33mw\u001b[33m4\u001b[33mw\u001b[33m9\u001b[33mW\u001b[33mg\u001b[33mX\u001b[33mc\u001b[33mQ\u001b[33m'\u001b[39m \u001b[47D"]
[0.159, "o", "\b\u001b[32m-\u001b[32m-\u001b[39m\u001b[39m \u001b[33m'\u001b[33mh\u001b[33mt\u001b[33mt\u001b[33mp\u001b[33ms\u001b[33m:\u001b[33m/\u001b[33m/\u001b[2C\u001b[33mw\u001b[33m.\u001b[33my\u001b[33mo\u001b[33mu\u001b[33mt\u001b[33mu\u001b[33mb\u001b[33me\u001b[33m.\u001b[33mc\u001b[33mo\u001b[33mm\u001b[33m/\u001b[33mw\u001b[33ma\u001b[33mt\u001b[33mc\u001b[33mh\u001b[33m?\u001b[33mv\u001b[33m=\u001b[33md\u001b[33mQ\u001b[33mw\u001b[33m4\u001b[33mw\u001b[33m9\u001b[33mW\u001b[33mg\u001b[33mX\u001b[33mc\u001b[33mQ\u001b[33m'\u001b[39m \u001b[47D"]
[0.140, "o", "\b\u001b[32m-\u001b[32mv\u001b[39m\u001b[39m \u001b[33m'\u001b[33mh\u001b[33mt\u001b[33mt\u001b[33mp\u001b[33ms\u001b[33m:\u001b[33m/\u001b[33m/\u001b[2C\u001b[33mw\u001b[33m.\u001b[33my\u001b[33mo\u001b[33mu\u001b[33mt\u001b[33mu\u001b[33mb\u001b[33me\u001b[33m.\u001b[33mc\u001b[33mo\u001b[33mm\u001b[33m/\u001b[33mw\u001b[33ma\u001b[33mt\u001b[33mc\u001b[33mh\u001b[33m?\u001b[33mv\u001b[33m=\u001b[33md\u001b[33mQ\u001b[33mw\u001b[33m4\u001b[33mw\u001b[33m9\u001b[33mW\u001b[33mg\u001b[33mX\u001b[33mc\u001b[33mQ\u001b[33m'\u001b[39m \u001b[47D"]
[0.118, "o", "\b\u001b[32mv\u001b[32mi\u001b[39m\u001b[39m \u001b[33m'\u001b[33mh\u001b[33mt\u001b[33mt\u001b[33mp\u001b[33ms\u001b[33m:\u001b[33m/\u001b[33m/\u001b[2C\u001b[33mw\u001b[33m.\u001b[33my\u001b[33mo\u001b[33mu\u001b[33mt\u001b[33mu\u001b[33mb\u001b[33me\u001b[33m.\u001b[33mc\u001b[33mo\u001b[33mm\u001b[33m/\u001b[33mw\u001b[33ma\u001b[33mt\u001b[33mc\u001b[33mh\u001b[33m?\u001b[33mv\u001b[33m=\u001b[33md\u001b[33mQ\u001b[33mw\u001b[33m4\u001b[33mw\u001b[33m9\u001b[33mW\u001b[33mg\u001b[33mX\u001b[33mc\u001b[33mQ\u001b[33m'\u001b[39m \u001b[47D"]
[0.109, "o", "\b\u001b[32mi\u001b[32md\u001b[39m\u001b[39m \u001b[33m'\u001b[33mh\u001b[33mt\u001b[33mt\u001b[33mp\u001b[33ms\u001b[33m:\u001b[33m/\u001b[33m/\u001b[2C\u001b[33mw\u001b[33m.\u001b[33my\u001b[33mo\u001b[33mu\u001b[33mt\u001b[33mu\u001b[33mb\u001b[33me\u001b[33m.\u001b[33mc\u001b[33mo\u001b[33mm\u001b[33m/\u001b[33mw\u001b[33ma\u001b[33mt\u001b[33mc\u001b[33mh\u001b[33m?\u001b[33mv\u001b[33m=\u001b[33md\u001b[33mQ\u001b[33mw\u001b[33m4\u001b[33mw\u001b[33m9\u001b[33mW\u001b[33mg\u001b[33mX\u001b[33mc\u001b[33mQ\u001b[33m'\u001b[39m \u001b[47D"]
[0.090, "o", "\b\u001b[32md\u001b[32me\u001b[39m\u001b[39m \u001b[33m'\u001b[33mh\u001b[33mt\u001b[33mt\u001b[33mp\u001b[33ms\u001b[33m:\u001b[33m/\u001b[33m/\u001b[2C\u001b[33mw\u001b[33m.\u001b[33my\u001b[33mo\u001b[33mu\u001b[33mt\u001b[33mu\u001b[33mb\u001b[33me\u001b[33m.\u001b[33mc\u001b[33mo\u001b[33mm\u001b[33m/\u001b[33mw\u001b[33ma\u001b[33mt\u001b[33mc\u001b[33mh\u001b[33m?\u001b[33mv\u001b[33m=\u001b[33md\u001b[33mQ\u001b[33mw\u001b[33m4\u001b[33mw\u001b[33m9\u001b[33mW\u001b[33mg\u001b[33mX\u001b[33mc\u001b[33mQ\u001b[33m'\u001b[39m \u001b[47D"]
[0.146, "o", "\b\u001b[32me\u001b[32mo\u001b[39m\u001b[39m \u001b[33m'\u001b[33mh\u001b[33mt\u001b[33mt\u001b[33mp\u001b[33ms\u001b[33m:\u001b[33m/\u001b[33m/\u001b[2C\u001b[33mw\u001b[33m.\u001b[33my\u001b[33mo\u001b[33mu\u001b[33mt\u001b[33mu\u001b[33mb\u001b[33me\u001b[33m.\u001b[33mc\u001b[33mo\u001b[33mm\u001b[33m/\u001b[33mw\u001b[33ma\u001b[33mt\u001b[33mc\u001b[33mh\u001b[33m?\u001b[33mv\u001b[33m=\u001b[33md\u001b[33mQ\u001b[33mw\u001b[33m4\u001b[33mw\u001b[33m9\u001b[33mW\u001b[33mg\u001b[33mX\u001b[33mc\u001b[33mQ\u001b[33m'\u001b[39m \u001b[47D"]
